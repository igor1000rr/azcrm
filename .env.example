# =========================================================
# AZ Group CRM — переменные окружения
# Генерация секретов:
#   AUTH_SECRET:            openssl rand -base64 32
#   ONLYOFFICE_JWT_SECRET:  openssl rand -hex 32
#   WHATSAPP_WORKER_TOKEN:  openssl rand -hex 32
#   CRON_SECRET:            openssl rand -hex 32
#   ENCRYPTION_KEY:         openssl rand -hex 32
#   VAPID:                  npm run vapid
# =========================================================

# ===== БАЗА ДАННЫХ =====
DB_USER=crm
DB_PASSWORD=crm
DB_NAME=azgroup_crm
DATABASE_URL="postgresql://crm:crm@localhost:5432/azgroup_crm?schema=public"

# ===== АВТОРИЗАЦИЯ =====
AUTH_SECRET="ОБЯЗАТЕЛЬНО-ЗАМЕНИТЬ-32+СИМВОЛОВ"
AUTH_URL="http://localhost:3000"
APP_PUBLIC_URL="http://localhost:3000"

# ===== ШИФРОВАНИЕ ЧУВСТВИТЕЛЬНЫХ ПОЛЕЙ =====
# AES-256-GCM ключ для шифрования OAuth-токенов в БД (Google Calendar и др).
# 32 байта = 64 hex-символа.
# КРИТИЧНО: после первой установки НЕ менять — иначе зашифрованные данные
# станут нечитаемыми, юзерам придётся переподключать Google Calendar.
ENCRYPTION_KEY="ОБЯЗАТЕЛЬНО-ЗАМЕНИТЬ-СЛУЧАЙНОЙ-СТРОКОЙ-64-HEX-СИМВОЛОВ"

# ===== ONLYOFFICE =====
ONLYOFFICE_PUBLIC_URL="http://localhost:8080"
ONLYOFFICE_JWT_SECRET="ОБЯЗАТЕЛЬНО-ЗАМЕНИТЬ-СЛУЧАЙНОЙ-СТРОКОЙ"

# ===== WHATSAPP WORKER =====
WHATSAPP_WORKER_URL="http://localhost:3100"
WHATSAPP_WORKER_TOKEN="ОБЯЗАТЕЛЬНО-ЗАМЕНИТЬ-СЛУЧАЙНОЙ-СТРОКОЙ"

# ===== GOOGLE OAUTH (Calendar) =====
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/google/callback"

# ===== ТЕЛЕФОНИЯ (Play) =====
# Когда Anna даст API ключ Play — заполнить
PLAY_API_BASE="https://api.play.pl/v1"
PLAY_API_KEY=""
# Скачивать записи разговоров локально (true) или хранить ссылки на Play (false)
SAVE_CALL_RECORDS="false"

# ===== PUSH-УВЕДОМЛЕНИЯ =====
# Сгенерировать: npm run vapid
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@azgroup.pl"

# ===== EMAIL (SMTP) =====
# Дублирование критичных уведомлений на email (передача лидов и т.п.)
# Если не настроено — email просто не будет отправляться, ошибок не будет
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="AZ Group CRM <noreply@azgroup.pl>"
SMTP_SECURE="false"

# ===== CRON =====
CRON_SECRET="ОБЯЗАТЕЛЬНО-ЗАМЕНИТЬ-СЛУЧАЙНОЙ-СТРОКОЙ"

# ===== ХРАНИЛИЩЕ =====
# Локально: ./storage  /  В docker: /app/storage
STORAGE_ROOT=""
