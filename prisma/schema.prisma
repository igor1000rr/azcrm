// ============================================================
// AZ Group CRM — схема БД
// Миграционная юридическая фирма в Польше
// ============================================================
// Архитектура:
//  - Client (физ. лицо) <-1:N-> Lead (конкретное дело)
//  - Funnel/Stage — кастомизируется админом
//  - WhatsApp каналы привязаны к менеджерам (общий + личные)
//  - Звонки из Play импортируются и привязываются к Client
//  - Документы: чек-лист (галочки) + внутренние через OnlyOffice
//  - Календарь: Google Calendar OAuth для каждого менеджера
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ПОЛЬЗОВАТЕЛИ И КОМАНДА
// ============================================================

enum UserRole {
  ADMIN  // Anna — полный доступ
  SALES  // менеджер продаж
  LEGAL  // менеджер легализации
}

enum UserStatus {
  ONLINE
  AWAY
  OFFLINE
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  name         String
  role         UserRole   @default(SALES)
  status       UserStatus @default(OFFLINE)
  avatar       String?
  isActive     Boolean    @default(true)
  phone        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  lastSeenAt   DateTime?

  // OAuth для Google Calendar
  googleAccessToken           String?   @db.Text
  googleAccessTokenExpiresAt  DateTime?
  googleRefreshToken          String?   @db.Text
  googleCalendarId            String?
  googleConnectedAt           DateTime?

  salesLeads     Lead[]            @relation("SalesManager")
  legalLeads     Lead[]            @relation("LegalManager")
  ownedClients   Client[]          @relation("ClientOwner")

  whatsappAccounts WhatsappAccount[]

  notes          Note[]
  payments       Payment[]
  events         LeadEvent[]
  tasks          Task[]            @relation("TaskAssignee")
  createdTasks   Task[]            @relation("TaskCreator")
  calendarEvents CalendarEvent[]
  sessions       Session[]
  auditLogs      AuditLog[]
  notifications  Notification[]
  uploadedFiles  ClientFile[]
  documents      InternalDocument[]
  sentMessages   ChatMessage[]     @relation("MessageSender")

  teamChatMembers   TeamChatMember[]
  teamChatMessages  TeamChatMessage[]
  pushSubscriptions PushSubscription[]

  // Финансы и учёт
  commissions     Commission[]
  workLogs        WorkLog[]
  expenses        Expense[]
  payrollConfig   PayrollConfig?
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  ipAddress String?
  userAgent String?  @db.Text
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

// ============================================================
// СПРАВОЧНИКИ — кастомизируются админом
// ============================================================

model City {
  id        String  @id @default(cuid())
  name      String  @unique
  isDefault Boolean @default(false)
  position  Int     @default(0)
  isActive  Boolean @default(true)

  clients   Client[]
  leads     Lead[]
  expenses  Expense[]
}

model Funnel {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  position    Int      @default(0)
  isActive    Boolean  @default(true)
  color       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stages       Stage[]
  leads        Lead[]
  docTemplates DocumentTemplate[]
  services     Service[]
}

model Stage {
  id        String   @id @default(cuid())
  funnelId  String
  funnel    Funnel   @relation(fields: [funnelId], references: [id], onDelete: Cascade)
  name      String
  color     String?
  position  Int      @default(0)
  isFinal   Boolean  @default(false)
  isLost    Boolean  @default(false)

  leads     Lead[]

  @@unique([funnelId, position])
  @@index([funnelId])
}

// ============================================================
// КЛИЕНТ (физ. лицо) — общая карточка для всех его дел
// ============================================================

model Client {
  id            String   @id @default(cuid())
  fullName      String
  birthDate     DateTime?
  nationality   String?
  phone         String   @unique
  // Дополнительные телефоны клиента (всего до 4 номеров: основной + 3 доп)
  altPhone      String?
  altPhone2     String?
  altPhone3     String?
  email         String?
  addressPL     String?  @db.Text
  addressHome   String?  @db.Text
  cityId        String?
  city          City?    @relation(fields: [cityId], references: [id])
  ownerId       String?
  owner         User?    @relation("ClientOwner", fields: [ownerId], references: [id])
  source        String?
  notes         String?  @db.Text
  isArchived    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  leads         Lead[]
  files         ClientFile[]
  calls         Call[]
  chatThreads   ChatThread[]

  @@index([phone])
  @@index([fullName])
  @@index([ownerId])
}

// ============================================================
// ЛИД — конкретное дело
// ============================================================

model Lead {
  id            String   @id @default(cuid())

  clientId      String
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  funnelId      String
  funnel        Funnel   @relation(fields: [funnelId], references: [id])
  stageId       String
  stage         Stage    @relation(fields: [stageId], references: [id])

  cityId        String?
  city          City?    @relation(fields: [cityId], references: [id])

  salesManagerId String?
  salesManager   User?   @relation("SalesManager", fields: [salesManagerId], references: [id])
  legalManagerId String?
  legalManager   User?   @relation("LegalManager", fields: [legalManagerId], references: [id])

  attorney      String?

  source        String?      // детальное описание источника ("WhatsApp: Yuliia")
  sourceKind    LeadSource?  // enum для аналитики (WHATSAPP/PHONE/TELEGRAM/MANUAL/...)
  whatsappAccountId String?
  whatsappAccount   WhatsappAccount? @relation(fields: [whatsappAccountId], references: [id])

  // Привязка к услуге из прайса (опционально — Анна может оставить пустым и писать сумму вручную)
  serviceId     String?
  service       Service? @relation(fields: [serviceId], references: [id])

  totalAmount   Decimal  @default(0) @db.Decimal(10, 2)

  firstContactAt    DateTime?
  fingerprintDate   DateTime?
  fingerprintLocation String?

  isArchived    Boolean  @default(false)
  closedAt      DateTime?
  summary       String?  @db.Text

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  documents     LeadDocument[]
  payments      Payment[]
  notes         Note[]
  events        LeadEvent[]
  calendarEvents CalendarEvent[]
  tasks         Task[]
  internalDocs  InternalDocument[]
  calls         Call[]
  chatThreads   ChatThread[]

  @@index([clientId])
  @@index([funnelId, stageId])
  @@index([salesManagerId])
  @@index([legalManagerId])
  @@index([cityId])
  @@index([serviceId])
  @@index([sourceKind, createdAt])
  @@index([fingerprintDate])
  @@index([isArchived])
}

// ============================================================
// ДОКУМЕНТЫ ЛИДА — чек-лист
// ============================================================

model DocumentTemplate {
  id        String   @id @default(cuid())
  funnelId  String
  funnel    Funnel   @relation(fields: [funnelId], references: [id], onDelete: Cascade)
  name      String
  position  Int      @default(0)
  isRequired Boolean @default(true)

  @@index([funnelId])
}

model LeadDocument {
  id          String   @id @default(cuid())
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  name        String
  isPresent   Boolean  @default(false)
  fileUrl     String?
  fileName    String?
  fileSize    Int?
  uploadedAt  DateTime?
  position    Int      @default(0)
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([leadId])
}

// ============================================================
// ФАЙЛЫ КЛИЕНТА — общая папка
// ============================================================

enum FileCategory {
  GENERAL
  PASSPORT
  CONTRACT
  CERTIFICATE
  PHOTO
  SCAN
  OTHER
}

model ClientFile {
  id          String       @id @default(cuid())
  clientId    String
  client      Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name        String
  fileUrl     String
  fileSize    Int
  mimeType    String?
  category    FileCategory @default(GENERAL)
  uploadedById String?
  uploadedBy   User?       @relation(fields: [uploadedById], references: [id])
  notes       String?      @db.Text
  createdAt   DateTime     @default(now())

  @@index([clientId])
  @@index([uploadedById])
}

// ============================================================
// ВНУТРЕННИЕ ДОКУМЕНТЫ — OnlyOffice
// ============================================================

enum InternalDocFormat {
  DOCX
  XLSX
  PPTX
  PDF
}

enum InternalDocSource {
  BLANK
  TEMPLATE
  UPLOAD
}

model DocumentBlueprint {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  fileUrl     String
  format      InternalDocFormat @default(DOCX)
  placeholders String[] @default([])
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  documents   InternalDocument[]
}

model InternalDocument {
  id           String   @id @default(cuid())
  leadId       String
  lead         Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  name         String
  fileUrl      String
  format       InternalDocFormat @default(DOCX)
  fileSize     Int?
  source       InternalDocSource @default(BLANK)
  blueprintId  String?
  blueprint    DocumentBlueprint? @relation(fields: [blueprintId], references: [id])
  ooDocumentKey String?
  createdById  String?
  createdBy    User?    @relation(fields: [createdById], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  version      Int      @default(1)
  parentId     String?
  parent       InternalDocument?  @relation("DocVersions", fields: [parentId], references: [id])
  versions     InternalDocument[] @relation("DocVersions")

  @@index([leadId])
  @@index([createdById])
}

// ============================================================
// ПЛАТЕЖИ
// ============================================================

enum PaymentMethod {
  CARD
  CASH
  TRANSFER
  OTHER
}

model Payment {
  id        String        @id @default(cuid())
  leadId    String
  lead      Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  amount    Decimal       @db.Decimal(10, 2)
  method    PaymentMethod @default(CASH)
  paidAt    DateTime      @default(now())
  notes     String?       @db.Text
  // Порядковый номер платежа в рамках лида (1 — предоплата, 2+ — последующие)
  // Используется для расчёта комиссий: с какого номера начинать начислять
  sequence  Int           @default(1)
  createdById String?
  createdBy   User?       @relation(fields: [createdById], references: [id])
  createdAt DateTime      @default(now())

  commissions Commission[]

  @@unique([leadId, sequence])
  @@index([leadId])
  @@index([paidAt])
}

// ============================================================
// ЗАМЕТКИ КОМАНДЫ
// ============================================================

model Note {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  body      String   @db.Text
  mentions  String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId])
  @@index([authorId])
}

// ============================================================
// СОБЫТИЯ И КАЛЕНДАРЬ
// ============================================================

enum EventKind {
  LEAD_CREATED
  STAGE_CHANGED
  MANAGER_CHANGED
  PAYMENT_ADDED
  PAYMENT_REMOVED
  DOCUMENT_TOGGLED
  DOCUMENT_UPLOADED
  FINGERPRINT_SET
  EXTRA_CALL_SET
  CALL_LOGGED
  MESSAGE_RECEIVED
  MESSAGE_SENT
  NOTE_ADDED
  TASK_CREATED
  ARCHIVED
  RESTORED
  CUSTOM
}

model LeadEvent {
  id        String    @id @default(cuid())
  leadId    String
  lead      Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  authorId  String?
  author    User?     @relation(fields: [authorId], references: [id])
  kind      EventKind
  payload   Json?
  message   String?   @db.Text
  createdAt DateTime  @default(now())

  @@index([leadId, createdAt])
}

enum CalendarKind {
  FINGERPRINT
  EXTRA_CALL
  CONSULTATION
  INTERNAL_MEETING
  CUSTOM
}

model CalendarEvent {
  id          String       @id @default(cuid())
  leadId      String?
  lead        Lead?        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  ownerId     String?
  owner       User?        @relation(fields: [ownerId], references: [id])
  kind        CalendarKind @default(CUSTOM)
  title       String
  description String?      @db.Text
  location    String?
  startsAt    DateTime
  endsAt      DateTime?
  googleId    String?
  reminderSent7d  Boolean  @default(false)
  reminderSent1d  Boolean  @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  participants CalendarEventParticipant[]

  @@index([leadId])
  @@index([ownerId])
  @@index([startsAt])
}

model CalendarEventParticipant {
  id        String        @id @default(cuid())
  eventId   String
  event     CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String
  status    String        @default("invited")

  @@unique([eventId, userId])
  @@index([userId])
}

// ============================================================
// КАНАЛЫ СВЯЗИ
// ============================================================

enum ChannelKind {
  WHATSAPP
  TELEGRAM
  PHONE
  EMAIL
}

model WhatsappAccount {
  id          String   @id @default(cuid())
  phoneNumber String   @unique
  label       String
  ownerId     String?
  owner       User?    @relation(fields: [ownerId], references: [id])
  isConnected Boolean  @default(false)
  sessionData String?  @db.Text
  lastSeenAt  DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  threads     ChatThread[]
  leads       Lead[]
  messages    ChatMessage[]

  @@index([ownerId])
}

model ChatThread {
  id          String   @id @default(cuid())
  channel     ChannelKind
  clientId    String?
  client      Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  leadId      String?
  lead        Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  whatsappAccountId String?
  whatsappAccount   WhatsappAccount? @relation(fields: [whatsappAccountId], references: [id])
  externalId  String?
  externalPhoneNumber String?
  externalUserName    String?
  unreadCount Int      @default(0)
  lastMessageAt DateTime?
  lastMessageText String? @db.Text
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  messages    ChatMessage[]

  @@index([clientId])
  @@index([leadId])
  @@index([channel, externalId])
}

enum MessageDirection {
  IN
  OUT
  SYSTEM
}

enum MessageType {
  TEXT
  IMAGE
  DOCUMENT
  AUDIO
  VIDEO
  LOCATION
  CONTACT
  TEMPLATE
  CALL
  SYSTEM
}

model ChatMessage {
  id          String           @id @default(cuid())
  threadId    String
  thread      ChatThread       @relation(fields: [threadId], references: [id], onDelete: Cascade)
  whatsappAccountId String?
  whatsappAccount   WhatsappAccount? @relation(fields: [whatsappAccountId], references: [id])
  direction   MessageDirection
  type        MessageType      @default(TEXT)
  body        String?          @db.Text
  mediaUrl    String?
  mediaName   String?
  mediaSize   Int?
  externalId  String?
  senderId    String?
  sender      User?            @relation("MessageSender", fields: [senderId], references: [id])
  isRead      Boolean          @default(false)
  deliveredAt DateTime?
  readAt      DateTime?
  createdAt   DateTime         @default(now())

  @@index([threadId, createdAt])
  @@index([externalId])
}

model ChatTemplate {
  id        String   @id @default(cuid())
  name      String
  body      String   @db.Text
  category  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// ЗВОНКИ — импорт из Play
// ============================================================

enum CallDirection {
  IN
  OUT
  MISSED
}

model Call {
  id          String        @id @default(cuid())
  clientId    String?
  client      Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  leadId      String?
  lead        Lead?         @relation(fields: [leadId], references: [id], onDelete: SetNull)
  externalId  String        @unique
  direction   CallDirection
  fromNumber  String
  toNumber    String
  startedAt   DateTime
  endedAt     DateTime?
  durationSec Int?
  recordUrl   String?
  recordLocalUrl String?
  managerId   String?
  metadata    Json?
  createdAt   DateTime      @default(now())

  @@index([clientId])
  @@index([leadId])
  @@index([startedAt])
  @@index([fromNumber])
}

// ============================================================
// ЗАДАЧИ
// ============================================================

enum TaskPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TaskStatus {
  OPEN
  DONE
  CANCELLED
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?      @db.Text
  leadId      String?
  lead        Lead?        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  assigneeId  String?
  assignee    User?        @relation("TaskAssignee", fields: [assigneeId], references: [id])
  creatorId   String
  creator     User         @relation("TaskCreator", fields: [creatorId], references: [id])
  status      TaskStatus   @default(OPEN)
  priority    TaskPriority @default(NORMAL)
  dueAt       DateTime?
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([assigneeId, status])
  @@index([leadId])
  @@index([dueAt])
}

// ============================================================
// АВТОМАТИЗАЦИИ
// ============================================================

model Automation {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  trigger     String
  triggerParams Json?
  action      String
  actionParams Json?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================================
// ВНУТРЕННИЕ ЧАТЫ КОМАНДЫ
// ============================================================

enum TeamChatKind {
  DIRECT
  GROUP
}

model TeamChat {
  id        String       @id @default(cuid())
  kind      TeamChatKind @default(DIRECT)
  name      String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  lastMessageAt DateTime?
  lastMessageText String? @db.Text

  members   TeamChatMember[]
  messages  TeamChatMessage[]
}

model TeamChatMember {
  id          String   @id @default(cuid())
  chatId      String
  chat        TeamChat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt    DateTime @default(now())
  lastReadAt  DateTime?

  @@unique([chatId, userId])
  @@index([userId])
}

model TeamChatMessage {
  id        String   @id @default(cuid())
  chatId    String
  chat      TeamChat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  body      String   @db.Text
  mediaUrl  String?
  createdAt DateTime @default(now())

  @@index([chatId, createdAt])
}

// ============================================================
// УВЕДОМЛЕНИЯ
// ============================================================

enum NotificationKind {
  LEAD_TRANSFERRED
  MENTION_IN_NOTE
  TASK_ASSIGNED
  TASK_OVERDUE
  PAYMENT_RECEIVED
  NEW_MESSAGE
  FINGERPRINT_REMINDER
  CUSTOM
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      NotificationKind
  title     String
  body      String?          @db.Text
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, isRead, createdAt])
}

// ============================================================
// PUSH-УВЕДОМЛЕНИЯ
// ============================================================

model PushSubscription {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint    String   @unique
  p256dh      String
  authKey     String
  userAgent   String?  @db.Text
  createdAt   DateTime @default(now())
  lastUsedAt  DateTime @default(now())

  @@index([userId])
}

// ============================================================
// АУДИТ-ЛОГ
// ============================================================

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entityType String?
  entityId   String?
  before    Json?
  after     Json?
  ipAddress String?
  userAgent String?  @db.Text
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([entityType, entityId])
}

// ============================================================
// НАСТРОЙКИ
// ============================================================

model Setting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

// ============================================================
// ИСТОЧНИК ЛИДА (для аналитики по каналам)
// ============================================================

enum LeadSource {
  WHATSAPP
  PHONE
  TELEGRAM
  EMAIL
  WEBSITE
  REFERRAL
  WALK_IN
  MANUAL
  IMPORT
  OTHER
}

// ============================================================
// УСЛУГИ (прайс-лист)
// ============================================================
// Анна как админ управляет ценами и % комиссии.
// При создании лида менеджер может выбрать услугу — цена подставится автоматически.
// Можно оставить пустым и ввести индивидуальную сумму вручную (скидки и т.д.)

model Service {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?  @db.Text
  basePrice   Decimal  @default(0) @db.Decimal(10, 2)

  // % комиссии менеджеру при оплате (разный для разных услуг)
  salesCommissionPercent Decimal @default(5) @db.Decimal(5, 2)
  legalCommissionPercent Decimal @default(5) @db.Decimal(5, 2)

  // Опциональная привязка к воронке (для авто-выбора услуг при создании лида)
  funnelId    String?
  funnel      Funnel?  @relation(fields: [funnelId], references: [id])

  isActive    Boolean  @default(true)
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  leads       Lead[]

  @@index([funnelId])
  @@index([isActive, position])
}

// ============================================================
// КОМИССИИ МЕНЕДЖЕРАМ (авторасчёт при оплате)
// ============================================================
// Логика: при создании платежа (см. addPayment) проверяется его порядковый номер.
// Если номер >= порога (Setting "commissionStartPayment", по дефолту 2 — со второго платежа),
// то для salesManager и legalManager создаются записи Commission с
// % из Service (или дефолтный 5% если услуга не задана).

model Commission {
  id            String   @id @default(cuid())

  paymentId     String
  payment       Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  role          UserRole // SALES или LEGAL — для какой роли начислено
  basePayment   Decimal  @db.Decimal(10, 2) // сумма платежа на момент расчёта
  percent       Decimal  @db.Decimal(5, 2)  // применённый %
  amount        Decimal  @db.Decimal(10, 2) // basePayment * percent / 100

  // Статус выплаты менеджеру
  paidOut       Boolean  @default(false)
  paidOutAt     DateTime?
  paidOutNotes  String?  @db.Text

  createdAt     DateTime @default(now())

  @@index([userId, paidOut])
  @@index([paymentId])
  @@index([createdAt])
}

// ============================================================
// УЧЁТ РАБОЧЕГО ВРЕМЕНИ
// ============================================================
// Каждый менеджер сам отмечает, в какие дни и с-по какое время был в офисе.
// Используется для премиальной сводки (часы * ставка).

model WorkLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  date      DateTime @db.Date
  startTime String   // "09:00"
  endTime   String   // "18:00"
  hours     Decimal  @db.Decimal(5, 2)
  notes     String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId, date])
  @@index([date])
}

// ============================================================
// РАСХОДЫ (только админ)
// ============================================================
// Анна сканирует документы (счета, чеки, аренда) и заносит расходы построчно.
// Фильтр по городу для сводного отчёта.

model Expense {
  id          String   @id @default(cuid())

  cityId      String?
  city        City?    @relation(fields: [cityId], references: [id])

  category    String   // "интернет", "аренда", "налог", "канцелярия" и т.д.
  amount      Decimal  @db.Decimal(10, 2)
  spentAt     DateTime
  description String?  @db.Text

  // Прикреплённый скан/файл (опционально)
  fileUrl     String?
  fileName    String?
  fileSize    Int?

  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([cityId])
  @@index([spentAt])
  @@index([category])
}

// ============================================================
// КОНФИГ ЗАРПЛАТЫ МЕНЕДЖЕРА
// ============================================================
// Используется в премиальной сводке: ставка/час, налог, фикс. часть.

model PayrollConfig {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  hourlyRate  Decimal  @default(0) @db.Decimal(10, 2)  // часовая ставка zł
  fixedSalary Decimal  @default(0) @db.Decimal(10, 2)  // фиксированная часть
  taxAmount   Decimal  @default(0) @db.Decimal(10, 2)  // налог в zł (фикс.)
  notes       String?  @db.Text

  updatedAt   DateTime @updatedAt
}
