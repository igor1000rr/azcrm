// ============================================================
// AZ Group CRM — схема БД
// Миграционная юридическая фирма в Польше
// ============================================================
// Архитектура:
//  - Client (физ. лицо) <-1:N-> Lead (конкретное дело)
//  - Funnel/Stage — кастомизируется админом
//  - WhatsApp/Telegram каналы привязаны к менеджерам (общий + личные)
//  - Звонки из Play импортируются и привязываются к Client
//  - Документы: чек-лист (галочки) + внутренние через OnlyOffice
//  - Календарь: Google Calendar OAuth для каждого менеджера
//  - Несколько услуг на одном лиде: через LeadService (M:N)
//  - Работодатель и город работы — для karta praca
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ПОЛЬЗОВАТЕЛИ И КОМАНДА
// ============================================================

enum UserRole {
  ADMIN  // Anna — полный доступ
  SALES  // менеджер продаж
  LEGAL  // менеджер легализации
}

enum UserStatus {
  ONLINE
  AWAY
  OFFLINE
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  name         String
  role         UserRole   @default(SALES)
  status       UserStatus @default(OFFLINE)
  avatar       String?
  isActive     Boolean    @default(true)
  phone        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  lastSeenAt   DateTime?

  // Принудительная смена пароля при следующем входе (первый вход / ресет админом)
  mustChangePassword Boolean @default(false)

  // Персональный % комиссии для этого менеджера. Перебивает % из услуги.
  // null = использовать % из услуги (старое поведение).
  // SALES получает этот % с ПЕРВОГО платежа лида (предоплата),
  // LEGAL — со ВТОРОГО платежа (после закрытия дела).
  commissionPercent Decimal? @db.Decimal(5, 2)

  // OAuth для Google Calendar
  googleAccessToken           String?   @db.Text
  googleAccessTokenExpiresAt  DateTime?
  googleRefreshToken          String?   @db.Text
  googleCalendarId            String?
  googleConnectedAt           DateTime?

  salesLeads     Lead[]            @relation("SalesManager")
  legalLeads     Lead[]            @relation("LegalManager")
  ownedClients   Client[]          @relation("ClientOwner")

  whatsappAccounts WhatsappAccount[]
  telegramAccounts TelegramAccount[]

  notes          Note[]
  payments       Payment[]
  events         LeadEvent[]
  tasks          Task[]            @relation("TaskAssignee")
  createdTasks   Task[]            @relation("TaskCreator")
  calendarEvents CalendarEvent[]
  sessions       Session[]
  auditLogs      AuditLog[]
  notifications  Notification[]
  uploadedFiles  ClientFile[]
  documents      InternalDocument[]
  sentMessages   ChatMessage[]     @relation("MessageSender")

  teamChatMembers   TeamChatMember[]
  teamChatMessages  TeamChatMessage[]
  pushSubscriptions PushSubscription[]

  // Финансы и учёт
  commissions     Commission[]
  workLogs        WorkLog[]
  expenses        Expense[]
  payrollConfig   PayrollConfig?
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  ipAddress String?
  userAgent String?  @db.Text
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

// ============================================================
// СПРАВОЧНИКИ — кастомизируются админом
// ============================================================

model City {
  id        String  @id @default(cuid())
  name      String  @unique
  isDefault Boolean @default(false)
  position  Int     @default(0)
  isActive  Boolean @default(true)

  clients     Client[]
  leads       Lead[]                          // город обращения лида
  workLeads   Lead[]   @relation("LeadWorkCity") // город работы (для karta praca)
  expenses    Expense[]
}

model Funnel {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  position    Int      @default(0)
  isActive    Boolean  @default(true)
  color       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stages       Stage[]
  leads        Lead[]
  docTemplates DocumentTemplate[]
  services     Service[]
}

model Stage {
  id        String   @id @default(cuid())
  funnelId  String
  funnel    Funnel   @relation(fields: [funnelId], references: [id], onDelete: Cascade)
  name      String
  color     String?
  position  Int      @default(0)
  isFinal   Boolean  @default(false)
  isLost    Boolean  @default(false)

  leads     Lead[]

  @@unique([funnelId, position])
  @@index([funnelId])
}

// ============================================================
// КЛИЕНТ (физ. лицо) — общая карточка для всех его дел
// ============================================================

model Client {
  id            String   @id @default(cuid())
  fullName      String
  birthDate     DateTime?
  nationality   String?
  phone         String   @unique
  // Дополнительные телефоны клиента (всего до 4 номеров: основной + 3 доп)
  altPhone      String?
  altPhone2     String?
  altPhone3     String?
  email         String?
  addressPL     String?  @db.Text
  addressHome   String?  @db.Text
  cityId        String?
  city          City?    @relation(fields: [cityId], references: [id])
  ownerId       String?
  owner         User?    @relation("ClientOwner", fields: [ownerId], references: [id])
  source        String?
  notes         String?  @db.Text
  isArchived    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  leads         Lead[]
  files         ClientFile[]
  calls         Call[]
  chatThreads   ChatThread[]

  @@index([phone])
  @@index([fullName])
  @@index([ownerId])
}

// ============================================================
// ЛИД — конкретное дело
// ============================================================

model Lead {
  id            String   @id @default(cuid())

  clientId      String
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  funnelId      String
  funnel        Funnel   @relation(fields: [funnelId], references: [id])
  stageId       String
  stage         Stage    @relation(fields: [stageId], references: [id])

  // Город обращения (где клиент пришёл)
  cityId        String?
  city          City?    @relation(fields: [cityId], references: [id])

  // Город работы (для karta praca — может отличаться от города обращения)
  workCityId    String?
  workCity      City?    @relation("LeadWorkCity", fields: [workCityId], references: [id])

  salesManagerId String?
  salesManager   User?   @relation("SalesManager", fields: [salesManagerId], references: [id])
  legalManagerId String?
  legalManager   User?   @relation("LegalManager", fields: [legalManagerId], references: [id])

  attorney      String?  // Pelnomocnik

  // Работодатель (ручной ввод, для karta praca)
  employerName  String?
  employerPhone String?

  source        String?      // детальное описание источника ("WhatsApp: Yuliia")
  sourceKind    LeadSource?  // enum для аналитики (WHATSAPP/PHONE/TELEGRAM/MANUAL/...)
  whatsappAccountId String?
  whatsappAccount   WhatsappAccount? @relation(fields: [whatsappAccountId], references: [id])
  telegramAccountId String?
  telegramAccount   TelegramAccount? @relation(fields: [telegramAccountId], references: [id])

  // Основная услуга (legacy + быстрая фильтрация). Полный список — в services[].
  serviceId     String?
  service       Service? @relation(fields: [serviceId], references: [id])

  // Все услуги лида (М:N через LeadService). Сумма totalAmount = sum(amount * qty).
  services      LeadService[]

  totalAmount   Decimal  @default(0) @db.Decimal(10, 2)

  firstContactAt    DateTime?
  fingerprintDate   DateTime?
  fingerprintLocation String?

  isArchived    Boolean  @default(false)
  closedAt      DateTime?
  summary       String?  @db.Text

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  documents     LeadDocument[]
  payments      Payment[]
  notes         Note[]
  events        LeadEvent[]
  calendarEvents CalendarEvent[]
  tasks         Task[]
  internalDocs  InternalDocument[]
  calls         Call[]
  chatThreads   ChatThread[]

  @@index([clientId])
  @@index([funnelId, stageId])
  @@index([salesManagerId])
  @@index([legalManagerId])
  @@index([cityId])
  @@index([workCityId])
  @@index([serviceId])
  @@index([sourceKind, createdAt])
  @@index([fingerprintDate])
  @@index([isArchived])
}

// ============================================================
// УСЛУГИ НА ЛИДЕ (M:N — несколько услуг)
// ============================================================
// Анна: «возможность добавить несколько услуг на лид» — напр. karta praca + открытие бизнеса.
// amount хранится персонально по лиду (можно дать скидку относительно basePrice).

model LeadService {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  serviceId String
  service   Service  @relation(fields: [serviceId], references: [id])

  amount    Decimal  @db.Decimal(10, 2)  // фактическая цена для этого лида
  qty       Int      @default(1)
  notes     String?  @db.Text
  position  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([leadId])
  @@index([serviceId])
}

// ============================================================
// ДОКУМЕНТЫ ЛИДА — чек-лист
// ============================================================
// Шаблоны привязываются либо к Funnel (старый подход), либо к Service — БОЛЕЕ ГИБКО:
// разные услуги имеют разные требования к документам. При создании лида берём шаблоны
// из выбранной услуги (если есть) или из воронки (как fallback).

model DocumentTemplate {
  id        String   @id @default(cuid())
  funnelId  String?
  funnel    Funnel?  @relation(fields: [funnelId], references: [id], onDelete: Cascade)
  serviceId String?
  service   Service? @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  name      String
  position  Int      @default(0)
  isRequired Boolean @default(true)

  @@index([funnelId])
  @@index([serviceId])
}

model LeadDocument {
  id          String   @id @default(cuid())
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  name        String
  isPresent   Boolean  @default(false)
  fileUrl     String?
  fileName    String?
  fileSize    Int?
  uploadedAt  DateTime?
  position    Int      @default(0)
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([leadId])
}

// ============================================================
// ФАЙЛЫ КЛИЕНТА — общая папка
// ============================================================

enum FileCategory {
  GENERAL
  PASSPORT
  CONTRACT
  CERTIFICATE
  PHOTO
  SCAN
  OTHER
}

model ClientFile {
  id          String       @id @default(cuid())
  clientId    String
  client      Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name        String
  fileUrl     String
  fileSize    Int
  mimeType    String?
  category    FileCategory @default(GENERAL)
  uploadedById String?
  uploadedBy   User?       @relation(fields: [uploadedById], references: [id])
  notes       String?      @db.Text
  createdAt   DateTime     @default(now())

  @@index([clientId])
  @@index([uploadedById])
}

// ============================================================
// ВНУТРЕННИЕ ДОКУМЕНТЫ — OnlyOffice
// ============================================================

enum InternalDocFormat {
  DOCX
  XLSX
  PPTX
  PDF
}

enum InternalDocSource {
  BLANK
  TEMPLATE
  UPLOAD
}

model DocumentBlueprint {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  fileUrl     String
  format      InternalDocFormat @default(DOCX)
  placeholders String[] @default([])
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  documents   InternalDocument[]
}

model InternalDocument {
  id           String   @id @default(cuid())
  leadId       String
  lead         Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  name         String
  fileUrl      String
  format       InternalDocFormat @default(DOCX)
  fileSize     Int?
  source       InternalDocSource @default(BLANK)
  blueprintId  String?
  blueprint    DocumentBlueprint? @relation(fields: [blueprintId], references: [id])
  ooDocumentKey String?
  createdById  String?
  createdBy    User?    @relation(fields: [createdById], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  version      Int      @default(1)
  parentId     String?
  parent       InternalDocument?  @relation("DocVersions", fields: [parentId], references: [id])
  versions     InternalDocument[] @relation("DocVersions")

  @@index([leadId])
  @@index([createdById])
}

// ============================================================
// ПЛАТЕЖИ
// ============================================================

enum PaymentMethod {
  CARD
  CASH
  TRANSFER
  OTHER
}

model Payment {
  id        String        @id @default(cuid())
  leadId    String
  lead      Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  amount    Decimal       @db.Decimal(10, 2)
  method    PaymentMethod @default(CASH)
  paidAt    DateTime      @default(now())
  notes     String?       @db.Text
  // Порядковый номер платежа в рамках лида.
  // Используется для расчёта комиссий:
  //   sequence=1 → SALES (менеджер продаж получает свой %)
  //   sequence=2 → LEGAL (менеджер легализации получает свой %)
  //   sequence>=3 → комиссии не начисляются
  sequence  Int           @default(1)
  createdById String?
  createdBy   User?       @relation(fields: [createdById], references: [id])
  createdAt DateTime      @default(now())

  commissions Commission[]

  @@unique([leadId, sequence])
  @@index([leadId])
  @@index([paidAt])
}

// ============================================================
// ЗАМЕТКИ КОМАНДЫ
// ============================================================

model Note {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  body      String   @db.Text
  mentions  String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId])
  @@index([authorId])
}

// ============================================================
// СОБЫТИЯ И КАЛЕНДАРЬ
// ============================================================

enum EventKind {
  LEAD_CREATED
  STAGE_CHANGED
  MANAGER_CHANGED
  PAYMENT_ADDED
  PAYMENT_REMOVED
  DOCUMENT_TOGGLED
  DOCUMENT_UPLOADED
  FINGERPRINT_SET
  EXTRA_CALL_SET
  CALL_LOGGED
  MESSAGE_RECEIVED
  MESSAGE_SENT
  NOTE_ADDED
  TASK_CREATED
  ARCHIVED
  RESTORED
  CUSTOM
}

model LeadEvent {
  id        String    @id @default(cuid())
  leadId    String
  lead      Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  authorId  String?
  author    User?     @relation(fields: [authorId], references: [id])
  kind      EventKind
  payload   Json?
  message   String?   @db.Text
  createdAt DateTime  @default(now())

  @@index([leadId, createdAt])
}

enum CalendarKind {
  FINGERPRINT
  EXTRA_CALL
  CONSULTATION
  INTERNAL_MEETING
  CUSTOM
}

model CalendarEvent {
  id          String       @id @default(cuid())
  leadId      String?
  lead        Lead?        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  ownerId     String?
  owner       User?        @relation(fields: [ownerId], references: [id])
  kind        CalendarKind @default(CUSTOM)
  title       String
  description String?      @db.Text
  location    String?
  startsAt    DateTime
  endsAt      DateTime?
  googleId    String?
  reminderSent7d  Boolean  @default(false)
  reminderSent1d  Boolean  @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  participants CalendarEventParticipant[]

  @@index([leadId])
  @@index([ownerId])
  @@index([startsAt])
}

model CalendarEventParticipant {
  id        String        @id @default(cuid())
  eventId   String
  event     CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String
  status    String        @default("invited")

  @@unique([eventId, userId])
  @@index([userId])
}

// ============================================================
// КАНАЛЫ СВЯЗИ
// ============================================================

enum ChannelKind {
  WHATSAPP
  TELEGRAM
  PHONE
  EMAIL
}

model WhatsappAccount {
  id          String   @id @default(cuid())
  phoneNumber String   @unique
  label       String
  ownerId     String?
  owner       User?    @relation(fields: [ownerId], references: [id])
  isConnected Boolean  @default(false)
  sessionData String?  @db.Text
  lastSeenAt  DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  threads     ChatThread[]
  leads       Lead[]
  messages    ChatMessage[]

  @@index([ownerId])
}

// ============================================================
// TELEGRAM КАНАЛ
// ============================================================
// Отдельный бот через grammy/Bot API. Аналогично WhatsApp — бот принимает
// сообщения, пересылает в CRM webhook, CRM создаёт лида из нового чата.

model TelegramAccount {
  id          String   @id @default(cuid())
  botToken    String   // BotFather token, хранится в ОТКРЫТОМ виде (в БД, доступно только админу)
  botUsername String   @unique  // @azgroup_bot
  label       String   // имя канала для UI
  ownerId     String?
  owner       User?    @relation(fields: [ownerId], references: [id])
  isConnected Boolean  @default(false)
  isActive    Boolean  @default(true)
  webhookUrl  String?  // URL установленного webhook'а (с подписью)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lastSeenAt  DateTime?

  threads     ChatThread[]
  leads       Lead[]
  messages    ChatMessage[]

  @@index([ownerId])
}

model ChatThread {
  id          String   @id @default(cuid())
  channel     ChannelKind
  clientId    String?
  client      Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  leadId      String?
  lead        Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  whatsappAccountId String?
  whatsappAccount   WhatsappAccount? @relation(fields: [whatsappAccountId], references: [id])
  telegramAccountId String?
  telegramAccount   TelegramAccount? @relation(fields: [telegramAccountId], references: [id])
  externalId  String?
  externalPhoneNumber String?
  externalUserName    String?
  unreadCount Int      @default(0)
  lastMessageAt DateTime?
  lastMessageText String? @db.Text
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  messages    ChatMessage[]

  @@index([clientId])
  @@index([leadId])
  @@index([channel, externalId])
}

enum MessageDirection {
  IN
  OUT
  SYSTEM
}

enum MessageType {
  TEXT
  IMAGE
  DOCUMENT
  AUDIO
  VIDEO
  LOCATION
  CONTACT
  TEMPLATE
  CALL
  SYSTEM
}

model ChatMessage {
  id          String           @id @default(cuid())
  threadId    String
  thread      ChatThread       @relation(fields: [threadId], references: [id], onDelete: Cascade)
  whatsappAccountId String?
  whatsappAccount   WhatsappAccount? @relation(fields: [whatsappAccountId], references: [id])
  telegramAccountId String?
  telegramAccount   TelegramAccount? @relation(fields: [telegramAccountId], references: [id])
  direction   MessageDirection
  type        MessageType      @default(TEXT)
  body        String?          @db.Text
  mediaUrl    String?
  mediaName   String?
  mediaSize   Int?
  externalId  String?
  senderId    String?
  sender      User?            @relation("MessageSender", fields: [senderId], references: [id])
  isRead      Boolean          @default(false)
  deliveredAt DateTime?
  readAt      DateTime?
  createdAt   DateTime         @default(now())

  @@index([threadId, createdAt])
  @@index([externalId])
}

model ChatTemplate {
  id        String   @id @default(cuid())
  name      String
  body      String   @db.Text
  category  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// ЗВОНКИ — импорт из Play
// ============================================================

enum CallDirection {
  IN
  OUT
  MISSED
}

model Call {
  id          String        @id @default(cuid())
  clientId    String?
  client      Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  leadId      String?
  lead        Lead?         @relation(fields: [leadId], references: [id], onDelete: SetNull)
  externalId  String        @unique
  direction   CallDirection
  fromNumber  String
  toNumber    String
  startedAt   DateTime
  endedAt     DateTime?
  durationSec Int?
  recordUrl   String?
  recordLocalUrl String?
  managerId   String?
  metadata    Json?
  createdAt   DateTime      @default(now())

  @@index([clientId])
  @@index([leadId])
  @@index([startedAt])
  @@index([fromNumber])
}

// ============================================================
// ЗАДАЧИ
// ============================================================

enum TaskPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TaskStatus {
  OPEN
  DONE
  CANCELLED
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?      @db.Text
  leadId      String?
  lead        Lead?        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  assigneeId  String?
  assignee    User?        @relation("TaskAssignee", fields: [assigneeId], references: [id])
  creatorId   String
  creator     User         @relation("TaskCreator", fields: [creatorId], references: [id])
  status      TaskStatus   @default(OPEN)
  priority    TaskPriority @default(NORMAL)
  dueAt       DateTime?
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([assigneeId, status])
  @@index([leadId])
  @@index([dueAt])
}

// ============================================================
// АВТОМАТИЗАЦИИ
// ============================================================

model Automation {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  trigger     String
  triggerParams Json?
  action      String
  actionParams Json?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================================
// ВНУТРЕННИЕ ЧАТЫ КОМАНДЫ
// ============================================================

enum TeamChatKind {
  DIRECT
  GROUP
}

model TeamChat {
  id        String       @id @default(cuid())
  kind      TeamChatKind @default(DIRECT)
  name      String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  lastMessageAt DateTime?
  lastMessageText String? @db.Text

  members   TeamChatMember[]
  messages  TeamChatMessage[]
}

model TeamChatMember {
  id          String   @id @default(cuid())
  chatId      String
  chat        TeamChat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt    DateTime @default(now())
  lastReadAt  DateTime?

  @@unique([chatId, userId])
  @@index([userId])
}

