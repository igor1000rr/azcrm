// ============================================================
// УСЛУГИ (прайс-лист)
// ============================================================
// Анна как админ управляет ценами и % комиссии.
// При создании лида менеджер может выбрать одну или НЕСКОЛЬКО услуг.
// Чек-лист документов берётся из DocumentTemplate связанных с услугой.

model Service {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?  @db.Text
  basePrice   Decimal  @default(0) @db.Decimal(10, 2)

  // % комиссии менеджеру при оплате (используется как дефолт если у юзера
  // не задан персональный User.commissionPercent)
  salesCommissionPercent Decimal @default(5) @db.Decimal(5, 2)
  legalCommissionPercent Decimal @default(5) @db.Decimal(5, 2)

  // Опциональная привязка к воронке (для авто-выбора услуг при создании лида)
  funnelId    String?
  funnel      Funnel?  @relation(fields: [funnelId], references: [id])

  isActive    Boolean  @default(true)
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  leads        Lead[]
  leadServices LeadService[]
  docTemplates DocumentTemplate[]

  @@index([funnelId])
  @@index([isActive, position])
}

// ============================================================
// КОМИССИИ МЕНЕДЖЕРАМ (авторасчёт при оплате)
// ============================================================
// Логика начисления (Anna 28.04.2026):
//   - SALES (менеджер продаж, кто привёл клиента) получает % от ПЕРВОГО
//     платежа лида (sequence=1, обычно предоплата).
//   - LEGAL (специалист по легализации, кто закрывает дело) получает %
//     от ВТОРОГО платежа (sequence=2, обычно финальный после закрытия).
//   - Платежи sequence=3+ комиссий не генерируют.
// % берётся в порядке приоритета:
//   1. User.commissionPercent (персональный, если задан)
//   2. Service.salesCommissionPercent / legalCommissionPercent (по основной услуге)
//   3. 5% по умолчанию (если нет ни того, ни другого)

model Commission {
  id            String   @id @default(cuid())

  paymentId     String
  payment       Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  role          UserRole // SALES или LEGAL — для какой роли начислено
  basePayment   Decimal  @db.Decimal(10, 2)
  percent       Decimal  @db.Decimal(5, 2)
  amount        Decimal  @db.Decimal(10, 2)

  paidOut       Boolean  @default(false)
  paidOutAt     DateTime?
  paidOutNotes  String?  @db.Text

  createdAt     DateTime @default(now())

  @@index([userId, paidOut])
  @@index([paymentId])
  @@index([createdAt])
}

// ============================================================
// УЧЁТ РАБОЧЕГО ВРЕМЕНИ
// ============================================================

model WorkLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  date      DateTime @db.Date
  startTime String
  endTime   String
  hours     Decimal  @db.Decimal(5, 2)
  notes     String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId, date])
  @@index([date])
}

// ============================================================
// РАСХОДЫ (только админ)
// ============================================================

model Expense {
  id          String   @id @default(cuid())

  cityId      String?
  city        City?    @relation(fields: [cityId], references: [id])

  category    String
  amount      Decimal  @db.Decimal(10, 2)
  spentAt     DateTime
  description String?  @db.Text

  fileUrl     String?
  fileName    String?
  fileSize    Int?

  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([cityId])
  @@index([spentAt])
  @@index([category])
}

// ============================================================
// КОНФИГ ЗАРПЛАТЫ МЕНЕДЖЕРА
// ============================================================
// Структура зарплаты (по требованию Anna):
//   Зп чистая    = ставка × часы + премии
//   Грязными свои = зп чистая + ZUS + PIT
//
// Anna вводит: hourlyRate (ставка/час), zus, pit
// Часы берутся из WorkLog, премии — из Commission за период.
//
// Поля fixedSalary и taxAmount оставлены для совместимости со старыми
// данными (если были введены), но в новом UI не используются.

model PayrollConfig {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  hourlyRate  Decimal  @default(0) @db.Decimal(10, 2)

  // ZUS — польский соцстрах. Вычитается из «грязных своих» при расчёте зп чистой.
  zus         Decimal  @default(0) @db.Decimal(10, 2)
  // PIT — польский подоходный налог.
  pit         Decimal  @default(0) @db.Decimal(10, 2)

  // Legacy поля — больше не используются в UI, оставлены для существующих данных
  fixedSalary Decimal  @default(0) @db.Decimal(10, 2)
  taxAmount   Decimal  @default(0) @db.Decimal(10, 2)

  notes       String?  @db.Text

  updatedAt   DateTime @updatedAt
}
